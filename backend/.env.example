# SERVER CONFIG
PORT=4000
NODE_ENV=development
BACKEND_URL=https://bcb-global.com
FRONTEND_URL=https://bcb-global.com

# AUTH
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura
JWT_REFRESH_SECRET=otra_clave_para_refresh_tokens

# DATABASE (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=bcb_global

# REDIS
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# TELEGRAM BOTS
TELEGRAM_BOT_TOKEN_ADMIN=your_token
TELEGRAM_BOT_TOKEN_RETIROS=your_token
TELEGRAM_BOT_TOKEN_SECRETARIA=your_token
TELEGRAM_CHAT_ADMIN=your_chat_id
TELEGRAM_CHAT_RETIROS=your_chat_id
TELEGRAM_CHAT_SECRETARIA=your_chat_id
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# LOGGING
LOG_LEVEL=info
